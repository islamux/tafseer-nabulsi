{
  "surah_id": 101,
  "name": "القارعة",
  "ayahs": [
    {
      "number": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 2,
      "text": "مَا ٱلْقَارِعَةُ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 3,
      "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 4,
      "text": "يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 5,
      "text": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 6,
      "text": "فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 7,
      "text": "فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 8,
      "text": "وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 9,
      "text": "فَأُمُّهُۥ هَاوِيَةٌۭ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 10,
      "text": "وَمَآ أَدْرَىٰكَ مَا هِيَهْ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 11,
      "text": "نَارٌ حَامِيَةٌۢ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    }
  ]
}