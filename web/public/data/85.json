{
  "surah_id": 85,
  "name": "البروج",
  "ayahs": [
    {
      "number": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 2,
      "text": "وَٱلْيَوْمِ ٱلْمَوْعُودِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 3,
      "text": "وَشَاهِدٍۢ وَمَشْهُودٍۢ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 4,
      "text": "قُتِلَ أَصْحَٰبُ ٱلْأُخْدُودِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 5,
      "text": "ٱلنَّارِ ذَاتِ ٱلْوَقُودِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 6,
      "text": "إِذْ هُمْ عَلَيْهَا قُعُودٌۭ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 7,
      "text": "وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌۭ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 8,
      "text": "وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 9,
      "text": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ شَهِيدٌ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 10,
      "text": "إِنَّ ٱلَّذِينَ فَتَنُوا۟ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ ثُمَّ لَمْ يَتُوبُوا۟ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ ٱلْحَرِيقِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 11,
      "text": "إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ جَنَّٰتٌۭ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 12,
      "text": "إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 13,
      "text": "إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 14,
      "text": "وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 15,
      "text": "ذُو ٱلْعَرْشِ ٱلْمَجِيدُ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 16,
      "text": "فَعَّالٌۭ لِّمَا يُرِيدُ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 17,
      "text": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 18,
      "text": "فِرْعَوْنَ وَثَمُودَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 19,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍۢ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 20,
      "text": "وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 21,
      "text": "بَلْ هُوَ قُرْءَانٌۭ مَّجِيدٌۭ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 22,
      "text": "فِى لَوْحٍۢ مَّحْفُوظٍۭ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    }
  ]
}