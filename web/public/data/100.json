{"surah_id":100,"name":"العاديات","ayahs":[{"number":1,"text":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَٰدِيَٰتِ ضَبْحًۭا","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":2,"text":"فَٱلْمُورِيَٰتِ قَدْحًۭا","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":3,"text":"فَٱلْمُغِيرَٰتِ صُبْحًۭا","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":4,"text":"فَأَثَرْنَ بِهِۦ نَقْعًۭا","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":5,"text":"فَوَسَطْنَ بِهِۦ جَمْعًا","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":6,"text":"إِنَّ ٱلْإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٌۭ","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":7,"text":"وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌۭ","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":8,"text":"وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":9,"text":"۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":10,"text":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}},{"number":11,"text":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ","tafsir_short":"","tafsir_long":"","media":{"audio_url":"","video_url":""}}]}