# Web app environment variables (Vite).
# Copy to `.env` (or `.env.production`) and fill in for production builds.
# Local dev works without any of these set.

# Base URL where the tafsir JSON is served from.
# - UNSET (default): falls back to `/data`, served from web/public/data/ via `pnpm copy-data`.
# - PRODUCTION:      set to your Cloudflare R2 public URL (no trailing slash).
#                    Example: VITE_DATA_BASE=https://pub-abc123.r2.dev/data
VITE_DATA_BASE=

# Cloudflare Worker URL for bookmarks + reading progress sync.
# - UNSET (default): app works in localStorage-only mode (no cross-device sync).
# - LOCAL DEV:    VITE_API_BASE=http://localhost:8787/api  (run `wrangler dev` in workers/tafsir-api/)
# - PRODUCTION:   VITE_API_BASE=https://tafsir-api.<your-subdomain>.workers.dev/api
VITE_API_BASE=

# (Optional) Worker origin allow-listed in the Content-Security-Policy (index.html connect-src).
# Auto-derived from VITE_API_BASE at build time — only set this to override, e.g. if the Worker
# is served from a host different from VITE_API_BASE.
VITE_API_ORIGIN=
