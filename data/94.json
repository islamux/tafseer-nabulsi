{
  "surah_id": 94,
  "name": "الشرح",
  "ayahs": [
    {
      "number": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 2,
      "text": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 3,
      "text": "ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 4,
      "text": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 5,
      "text": "فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 6,
      "text": "إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 7,
      "text": "فَإِذَا فَرَغْتَ فَٱنصَبْ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 8,
      "text": "وَإِلَىٰ رَبِّكَ فَٱرْغَب",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    }
  ]
