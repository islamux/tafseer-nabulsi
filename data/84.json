{
  "surah_id": 84,
  "name": "الإنشقاق",
  "ayahs": [
    {
      "number": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 2,
      "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 3,
      "text": "وَإِذَا ٱلْأَرْضُ مُدَّتْ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 4,
      "text": "وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 5,
      "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 6,
      "text": "يَٰٓأَيُّهَا ٱلْإِنسَٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًۭا فَمُلَٰقِيهِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 7,
      "text": "فَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ بِيَمِينِهِۦ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 8,
      "text": "فَسَوْفَ يُحَاسَبُ حِسَابًۭا يَسِيرًۭا",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 9,
      "text": "وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًۭا",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 10,
      "text": "وَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ وَرَآءَ ظَهْرِهِۦ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 11,
      "text": "فَسَوْفَ يَدْعُوا۟ ثُبُورًۭا",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 12,
      "text": "وَيَصْلَىٰ سَعِيرًا",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 13,
      "text": "إِنَّهُۥ كَانَ فِىٓ أَهْلِهِۦ مَسْرُورًا",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 14,
      "text": "إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 15,
      "text": "بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًۭا",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 16,
      "text": "فَلَآ أُقْسِمُ بِٱلشَّفَقِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 17,
      "text": "وَٱلَّيْلِ وَمَا وَسَقَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 18,
      "text": "وَٱلْقَمَرِ إِذَا ٱتَّسَقَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 19,
      "text": "لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍۢ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 20,
      "text": "فَمَا لَهُمْ لَا يُؤْمِنُونَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 21,
      "text": "وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ ۩",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 22,
      "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِّبُونَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 23,
      "text": "وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 24,
      "text": "فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 25,
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۭ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    }
  ]
}