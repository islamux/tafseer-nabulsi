{
  "surah_id": 107,
  "name": "الماعون",
  "ayahs": [
    {
      "number": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 2,
      "text": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 3,
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 4,
      "text": "فَوَيْلٌۭ لِّلْمُصَلِّينَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 5,
      "text": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 6,
      "text": "ٱلَّذِينَ هُمْ يُرَآءُونَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    },
    {
      "number": 7,
      "text": "وَيَمْنَعُونَ ٱلْمَاعُونَ",
      "tafsir_short": "",
      "tafsir_long": "",
      "media": {
        "audio_url": "",
        "video_url": ""
      }
    }
  ]
